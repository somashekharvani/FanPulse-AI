# FanPulse AI Backend Configuration Template
# Copy this to .env in backend directory

# System Secret
JWT_SECRET=super-secret-key-for-development-only-replace-in-production

# Database Settings
# Supports sqlite:///./fanpulse.db (default fallback) or postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///./fanpulse.db

# Generative AI APIs
# Leave empty to utilize the grounded rules-based mock engine for offline testing
GEMINI_API_KEY=
